flowchart TB
    %% Thesis system architecture for threat infrastructure prediction

    subgraph A["A. Data Sources"]
        A1["CTI reports<br/>public threat reports / PDFs / blogs"]
        A2["IoC extraction results<br/>file / domain / IP / email"]
        A3["VirusTotal Details API<br/>metadata enrichment"]
        A4["VirusTotal Relationships API<br/>11 relation types"]
        A5["Optional semantic source<br/>NER-based TTP entities"]
    end

    subgraph B["B. Data Preparation"]
        B1["IoC cleaning and normalization<br/>defang restore / hash merge / URL-IP folding / blacklist filtering / deduplication"]
        B2["Per-org VT enrichment<br/>L0 metadata + L1 neighbor discovery"]
        B3["Per-org knowledge graphs<br/>APT root + has_ioc + VT relation edges"]
        B4["Master KG merge<br/>node merge / edge union / org mapping"]
        B5["Master storage<br/>merged_kg.json + merged_kg.db"]
    end

    subgraph C["C. Heterogeneous Threat Infrastructure Graph"]
        C1["Node types<br/>apt / file / domain / ip / email"]
        C2["Relation types<br/>has_ioc, resolves_to, contacted_ip, contacted_domain,<br/>contacted_url, dropped_file, bundled_file, execution_parent,<br/>communicating_file, referrer_file, has_subdomain"]
        C3["Node attributes<br/>VT metadata / depth / org membership / optional TTP features"]
        C4["Edge attributes<br/>resolution_date / last_analysis_date / analysis stats / source reports"]
    end

    subgraph D["D. Split Builder and Evaluation Protocols"]
        D1["Protocol A<br/>random edge split<br/>80 / 10 / 10"]
        D2["Protocol B<br/>temporal split<br/>train <= 2024 / valid = 2025 / test >= 2026"]
        D3["Protocol B variants<br/>B-Pragmatic / B-Strict / B-DNS"]
        D4["Transductive vs Inductive partition<br/>seen-node vs unseen-node temporal prediction"]
        D5["Protocol C<br/>report-group split<br/>incident-conditioned evaluation"]
    end

    subgraph E["E. Representation and Prediction Engine"]
        E1["Type-constrained candidate generator<br/>relation-specific tail node space"]
        E2["Baselines<br/>random / degree / common-neighbor / relation frequency"]
        E3["KG embedding models<br/>TransE / DistMult / ComplEx"]
        E4["Heterogeneous graph encoder<br/>R-GCN or feature-aware message passing"]
        E5["Split-aware feature construction<br/>train-only vocabularies / train-only statistics / optional temporal encoding"]
        E6["Link scoring head<br/>score(h, r, t)"]
        E7["Training strategy<br/>type-constrained negative sampling + filtered ranking"]
    end

    subgraph F["F. Tasks and Outputs"]
        F1["Task 1: temporal heterogeneous link prediction<br/>predict missing infrastructure edges"]
        F2["Task 2: incident-conditioned IoC expansion<br/>given seed IoCs, recover related L1 infrastructure"]
        F3["Task 3: prediction-driven attribution<br/>predicted neighbors -> org overlap voting"]
        F4["Outputs<br/>ranked candidate edges / expanded infrastructure set / attribution evidence chain"]
    end

    subgraph G["G. Metrics and Analysis"]
        G1["Link prediction metrics<br/>MRR / Hits@1 / Hits@10<br/>per-relation + micro / macro"]
        G2["IoC expansion metrics<br/>Recall@K / Precision@K / NDCG@K"]
        G3["Attribution metrics<br/>coverage / deterministic accuracy / tie rate / AP@Coverage"]
        G4["Analysis layer<br/>temporal drift / relation ablation / per-org behavior / case studies"]
    end

