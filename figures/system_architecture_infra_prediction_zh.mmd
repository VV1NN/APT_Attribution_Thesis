flowchart TB
    %% 中文版：威脅基礎設施預測系統架構圖

    subgraph A["A. 資料來源"]
        A1["CTI 報告<br/>公開威脅報告 / PDF / 部落格"]
        A2["IoC 擷取結果<br/>file / domain / IP / email"]
        A3["VirusTotal Details API<br/>節點屬性豐富化"]
        A4["VirusTotal Relationships API<br/>11 種關係擴展"]
        A5["可選語意來源<br/>NER 抽取的 TTP 實體"]
    end

    subgraph B["B. 資料準備"]
        B1["IoC 清洗與正規化<br/>defang 還原 / hash 合併 / URL-IP 折疊 / 黑名單過濾 / 去重"]
        B2["各組織 VT 豐富化<br/>L0 metadata 與 L1 鄰居發現"]
        B3["各組織局部知識圖譜<br/>APT 根節點 + has_ioc + VT 關係邊"]
        B4["Master KG 合併<br/>節點合併 / 邊聯集 / 組織對映"]
        B5["主圖儲存<br/>merged_kg.json + merged_kg.db"]
    end

    subgraph C["C. 異質威脅基礎設施知識圖譜"]
        C1["節點類型<br/>apt / file / domain / ip / email"]
        C2["關係類型<br/>has_ioc、resolves_to、contacted_ip、contacted_domain、<br/>contacted_url、dropped_file、bundled_file、execution_parent、<br/>communicating_file、referrer_file、has_subdomain"]
        C3["節點屬性<br/>VT metadata / depth / org membership / 可選 TTP 特徵"]
        C4["邊屬性<br/>resolution_date / last_analysis_date / 分析統計 / source reports"]
    end

    subgraph D["D. Split 與評估協定"]
        D1["Protocol A<br/>隨機邊切分<br/>80 / 10 / 10"]
        D2["Protocol B<br/>時間切分<br/>訓練 ≤ 2024 / 驗證 = 2025 / 測試 ≥ 2026"]
        D3["Protocol B 變體<br/>B-Pragmatic / B-Strict / B-DNS"]
        D4["Transductive 與 Inductive 分割<br/>已見節點預測 / 未見節點冷啟動預測"]
        D5["Protocol C<br/>報告群組切分<br/>incident-conditioned 評估"]
    end

    subgraph E["E. 表徵學習與預測引擎"]
        E1["型別約束候選集合<br/>依 relation 限制 tail 節點空間"]
        E2["基線方法<br/>random / degree / common-neighbor / relation frequency"]
        E3["KG 嵌入模型<br/>TransE / DistMult / ComplEx"]
        E4["異質圖編碼器<br/>R-GCN 或 feature-aware message passing"]
        E5["Split-aware 特徵建構<br/>僅用 train 建 vocabulary / 統計量 / 可選時間編碼"]
        E6["連結打分模組<br/>score(h, r, t)"]
        E7["訓練策略<br/>型別約束負採樣 + filtered ranking"]
    end

    subgraph F["F. 任務與輸出"]
        F1["Task 1：時間式異質連結預測<br/>預測缺失的威脅基礎設施邊"]
        F2["Task 2：事件條件式 IoC 擴展<br/>由 seed IoCs 找回相關 L1 基礎設施"]
        F3["Task 3：預測驅動式歸因<br/>預測鄰居 → 與各組織歷史圖重疊投票"]
        F4["輸出結果<br/>候選邊排序 / 擴展後基礎設施集合 / 歸因證據鏈"]
    end

    subgraph G["G. 評估指標與分析"]
        G1["連結預測指標<br/>MRR / Hits@1 / Hits@10<br/>per-relation + micro / macro"]
        G2["IoC 擴展指標<br/>Recall@K / Precision@K / NDCG@K"]
        G3["歸因指標<br/>coverage / deterministic accuracy / tie rate / AP@Coverage"]
        G4["分析層<br/>temporal drift / relation ablation / per-org 行為 / case studies"]
    end

    A1 --> A2
    A2 --> B1
    A3 --> B2
